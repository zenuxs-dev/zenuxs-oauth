{
  "name": "zenuxs-oauth",
  "version": "3.0.0",
  "description": "Cross-platform OAuth 2.0 PKCE SDK for browser, React, and Node.js",
  "type": "module",
  "main": "./dist/browser/zenux-oauth.umd.js",
  "module": "./dist/browser/zenux-oauth.esm.js",
  "browser": "./dist/browser/zenux-oauth.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "import": "./dist/browser/zenux-oauth.esm.js",
        "require": "./dist/browser/zenux-oauth.umd.js"
      },
      "node": {
        "import": "./dist/server/index.mjs",
        "require": "./dist/server/index.cjs"
      },
      "default": "./dist/browser/zenux-oauth.umd.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "node": {
        "import": "./dist/server/index.mjs",
        "require": "./dist/server/index.cjs"
      },
      "default": "./dist/server/index.cjs"
    },
    "./core": {
      "types": "./dist/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.cjs",
      "default": "./dist/core/index.cjs"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "browser": {
        "import": "./dist/browser/zenux-oauth.esm.js",
        "require": "./dist/browser/zenux-oauth.umd.js"
      },
      "default": "./dist/browser/zenux-oauth.umd.js"
    },
    "./callback": {
      "browser": "./dist/browser/callback.html",
      "default": "./dist/browser/callback.html"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:setup && npm run build:rollup",
    "build:setup": "node build.mjs",
    "build:rollup": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "oauth",
    "oauth2",
    "pkce",
    "authentication",
    "authorization",
    "react",
    "nextjs",
    "node",
    "browser"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-terser": "^0.4.0"
  },
  "peerDependencies": {
    "node-fetch": "^3.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "node-fetch": {
      "optional": true
    },
    "undici": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "sideEffects": false
}